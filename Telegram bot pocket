import telebot
from telebot import types
from config import TOKEN

bot = telebot.TeleBot(TOKEN)

@bot.message_handler(commands=['start'])
def start(message):

    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)

    b1 = types.KeyboardButton("📊 Analyse")
    b2 = types.KeyboardButton("📈 Statistiques")
    b3 = types.KeyboardButton("ℹ️ Aide")

    markup.add(b1)
    markup.add(b2)
    markup.add(b3)

    bot.send_message(
        message.chat.id,
        "🤖 PocketBot\n\nBienvenue.",
        reply_markup=markup
    )

@bot.message_handler(func=lambda m: m.text=="📊 Analyse")
def analyse(message):

    bot.send_message(
        message.chat.id,
        """📊 Analyse

• RSI : 54
• EMA : Haussière
• Volatilité : Moyenne

Signal : Attendre
"""
    )

@bot.message_handler(func=lambda m: m.text=="📈 Statistiques")
def stats(message):

    bot.send_message(
        message.chat.id,
        """📈 Statistiques

Signaux envoyés : 0

Historique vide.
"""
    )

@bot.message_handler(func=lambda m: m.text=="ℹ️ Aide")
def aide(message):

    bot.send_message(
        message.chat.id,
        """Commandes disponibles :

/start
"""
    )

print("Bot lancé...")

bot.infinity_polling()
